{
  "enabledPlugins": {
    "github@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "discord@claude-plugins-official": true
  },
  "permissions": {
    "allow": [
      "Bash(poetry run:*)",
      "Bash(poetry install:*)",
      "Bash(poetry add:*)",
      "Bash(poetry lock:*)",
      "Bash(npm run:*)",
      "Bash(npm install:*)",
      "Bash(npx tsc:*)",
      "Bash(npx playwright:*)",
      "Bash(npx next *)",
      "Bash(python3:*)",
      "Bash(node *)",
      "Bash(pip show:*)",
      "Bash(pip index:*)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git --no-pager:*)",
      "Bash(gh issue:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr checks:*)",
      "Bash(gh api:*)",
      "Bash(psql:*)",
      "Bash(aws logs:*)",
      "Bash(aws cloudwatch get-*)",
      "Bash(aws cloudwatch list-*)",
      "Bash(aws cloudwatch describe-*)",
      "Bash(aws lambda list-*)",
      "Bash(aws lambda get-*)",
      "Bash(aws cloudformation describe-*)",
      "Bash(aws cloudformation list-*)",
      "Bash(aws s3 ls:*)",
