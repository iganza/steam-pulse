ENVIRONMENT=staging

# LLM backend + model routing
LLM_BACKEND=anthropic
LLM_MODEL__CHUNKING=claude-haiku-4-5-20251001
LLM_MODEL__MERGING=claude-sonnet-4-6
LLM_MODEL__SUMMARIZER=claude-sonnet-4-6
LLM_MODEL__GENRE_SYNTHESIS=claude-sonnet-4-6

# Analysis token budgets (must be large enough for full structured JSON output)
ANALYSIS_CHUNK_MAX_TOKENS=8192
ANALYSIS_MERGE_MAX_TOKENS=16384
ANALYSIS_SYNTHESIS_MAX_TOKENS=16384

# Phase-4 cross-genre synthesizer (one LLM call per genre per weekly refresh)
GENRE_SYNTHESIS_MAX_TOKENS=8000
GENRE_SYNTHESIS_PROMPT_VERSION=v1
GENRE_SYNTHESIS_MIN_GAME_REVIEW_COUNT=200
GENRE_SYNTHESIS_MAX_AGE_DAYS=7
GENRE_SYNTHESIS_ORCHESTRATOR_SFN_PARAM_NAME=/steampulse/staging/genre-synthesis/orchestrator-sfn-arn

# Secrets Manager names (Lambda calls get_secret_value(SecretId=name))
DB_SECRET_NAME=steampulse/staging/db-credentials
STEAM_API_KEY_SECRET_NAME=steampulse/staging/steam-api-key
RESEND_API_KEY_SECRET_NAME=steampulse/staging/resend-api-key
ANTHROPIC_API_KEY_SECRET_NAME=/steampulse/staging/anthropic-apikey

# SSM parameter names (resolved at Lambda cold start via get_parameter())
SFN_PARAM_NAME=/steampulse/staging/compute/sfn-arn
STEP_FUNCTIONS_PARAM_NAME=/steampulse/staging/compute/sfn-arn
APP_CRAWL_QUEUE_PARAM_NAME=/steampulse/staging/messaging/app-crawl-queue-url
REVIEW_CRAWL_QUEUE_PARAM_NAME=/steampulse/staging/messaging/review-crawl-queue-url
ASSETS_BUCKET_PARAM_NAME=/steampulse/staging/data/assets-bucket-name
EMAIL_QUEUE_PARAM_NAME=/steampulse/staging/messaging/email-queue-url

# SNS topic SSM parameter names
GAME_EVENTS_TOPIC_PARAM_NAME=/steampulse/staging/messaging/game-events-topic-arn
CONTENT_EVENTS_TOPIC_PARAM_NAME=/steampulse/staging/messaging/content-events-topic-arn
SYSTEM_EVENTS_TOPIC_PARAM_NAME=/steampulse/staging/messaging/system-events-topic-arn

# Spoke regions (comma-separated) — primary region must be included
SPOKE_REGIONS=us-west-2,us-east-1
SPOKE_CRAWL_QUEUE_URLS=
