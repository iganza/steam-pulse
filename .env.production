ENVIRONMENT=production

# LLM backend + model routing
LLM_BACKEND=anthropic
LLM_MODEL__CHUNKING=claude-haiku-4-5-20251001
LLM_MODEL__MERGING=claude-sonnet-4-6
LLM_MODEL__SUMMARIZER=claude-sonnet-4-6

# Analysis token budgets (must be large enough for full structured JSON output)
ANALYSIS_CHUNK_MAX_TOKENS=8192
ANALYSIS_MERGE_MAX_TOKENS=16384
ANALYSIS_SYNTHESIS_MAX_TOKENS=16384

# Secrets Manager names (Lambda calls get_secret_value(SecretId=name))
DB_SECRET_NAME=steampulse/production/db-credentials
STEAM_API_KEY_SECRET_NAME=steampulse/production/steam-api-key
RESEND_API_KEY_SECRET_NAME=steampulse/production/resend-api-key
ANTHROPIC_API_KEY_SECRET_NAME=/steampulse/production/anthropic-api-key

# SSM parameter names (resolved at Lambda cold start via get_parameter())
SFN_PARAM_NAME=/steampulse/production/compute/sfn-arn
STEP_FUNCTIONS_PARAM_NAME=/steampulse/production/compute/sfn-arn
APP_CRAWL_QUEUE_PARAM_NAME=/steampulse/production/messaging/app-crawl-queue-url
REVIEW_CRAWL_QUEUE_PARAM_NAME=/steampulse/production/messaging/review-crawl-queue-url
ASSETS_BUCKET_PARAM_NAME=/steampulse/production/data/assets-bucket-name
EMAIL_QUEUE_PARAM_NAME=/steampulse/production/messaging/email-queue-url

# SNS topic SSM parameter names
GAME_EVENTS_TOPIC_PARAM_NAME=/steampulse/production/messaging/game-events-topic-arn
CONTENT_EVENTS_TOPIC_PARAM_NAME=/steampulse/production/messaging/content-events-topic-arn
SYSTEM_EVENTS_TOPIC_PARAM_NAME=/steampulse/production/messaging/system-events-topic-arn

# Spoke regions (comma-separated) — primary region must be included
SPOKE_REGIONS=us-west-2,us-east-1,us-east-2,ca-central-1,eu-west-1,eu-central-1,eu-north-1,ap-south-1,ap-southeast-1,ap-northeast-1,ap-northeast-2,ap-southeast-2
SPOKE_CRAWL_QUEUE_URLS=
