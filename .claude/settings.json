      "Bash(aws sqs get-*)",
      "Bash(aws ce get-cost-and-usage:*)",
      "Bash(aws ecr describe-*)",
      "Bash(aws ecr list-*)",
      "Bash(aws cloudfront get-*)",
      "Bash(aws cloudfront list-*)",
      "Bash(aws codepipeline list-*)",
      "Bash(aws codepipeline get-*)",
      "Bash(find:*)",
      "Bash(wc:*)",
      "Bash(docker ps:*)",
      "Bash(docker logs:*)",
      "WebSearch"
