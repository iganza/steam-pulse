ANTHROPIC_API_KEY=
DATABASE_URL=postgresql://user:pass@localhost:5432/steampulse
STEAM_API_KEY=
RESEND_API_KEY=

# LLM model routing — one line per task. Add LLM_MODEL__<TASK>=<model_id> for new tasks.
LLM_MODEL__CHUNKING=us.anthropic.claude-haiku-4-5-20251001-v1:0
LLM_MODEL__MERGING=us.anthropic.claude-haiku-4-5-20251001-v1:0
LLM_MODEL__SUMMARIZER=us.anthropic.claude-sonnet-4-6

# Secrets Manager names — required by SteamPulseConfig.
# Local dev: set to "local" (db.py uses DATABASE_URL above, not resolved)
# Staging/prod: set to actual secret names e.g. steampulse/staging/db-credentials
DB_SECRET_NAME=local
STEAM_API_KEY_SECRET_NAME=local
RESEND_API_KEY_SECRET_NAME=local

# SSM parameter names — required by SteamPulseConfig.
# Local dev: set to "local" (not resolved locally)
# Staging/prod: set to actual SSM paths e.g. /steampulse/staging/compute/sfn-arn
SFN_PARAM_NAME=local
STEP_FUNCTIONS_PARAM_NAME=local
APP_CRAWL_QUEUE_PARAM_NAME=local
REVIEW_CRAWL_QUEUE_PARAM_NAME=local
ASSETS_BUCKET_PARAM_NAME=local
EMAIL_QUEUE_PARAM_NAME=local
GAME_EVENTS_TOPIC_PARAM_NAME=local
CONTENT_EVENTS_TOPIC_PARAM_NAME=local
SYSTEM_EVENTS_TOPIC_PARAM_NAME=local

# Spoke regions (comma-separated, empty for local dev)
SPOKE_REGIONS=
SPOKE_CRAWL_QUEUE_URLS=

DEV_KEY=  # set to auto-fill unlock key in browser
